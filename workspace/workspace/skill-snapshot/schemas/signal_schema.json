{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Signal Schema",
  "description": "Schema for normalized signal definitions and classification",
  "type": "object",
  "required": ["time_column", "column_mappings", "time_range"],
  "properties": {
    "time_column": {
      "type": "string",
      "description": "Name of the time/datetime column"
    },
    "column_mappings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["original", "canonical", "data_type"],
        "properties": {
          "original": {"type": "string", "description": "Original column name from data file"},
          "canonical": {"type": "string", "description": "Normalized canonical name"},
          "unit": {"type": "string", "description": "Normalized unit"},
          "original_unit": {"type": "string", "description": "Original unit as found"},
          "data_type": {"type": "string", "enum": ["datetime64", "float64", "int64", "category", "string", "bool"]},
          "conversion_factor": {"type": ["number", "null"], "description": "Multiply original by this to get canonical"},
          "category": {"type": "string", "enum": ["inspection", "process", "control", "event", "metadata", "uncertain"]},
          "description": {"type": "string"}
        }
      }
    },
    "sampling_rate": {
      "type": "object",
      "properties": {
        "value": {"type": "number"},
        "unit": {"type": "string", "enum": ["Hz", "s", "min", "h"]}
      }
    },
    "time_range": {
      "type": "object",
      "required": ["start", "end"],
      "properties": {
        "start": {"type": "string", "format": "date-time"},
        "end": {"type": "string", "format": "date-time"},
        "duration_seconds": {"type": "number"},
        "timezone": {"type": "string"}
      }
    },
    "classification": {
      "type": "object",
      "properties": {
        "inspection_signals": {"type": "array", "items": {"type": "string"}},
        "process_parameters": {"type": "array", "items": {"type": "string"}},
        "control_variables": {"type": "array", "items": {"type": "string"}},
        "events": {"type": "array", "items": {"type": "string"}},
        "metadata_columns": {"type": "array", "items": {"type": "string"}},
        "uncertain": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "column": {"type": "string"},
              "possible_categories": {"type": "array", "items": {"type": "string"}},
              "reasoning": {"type": "string"}
            }
          }
        }
      }
    },
    "quality_notes": {
      "type": "array",
      "items": {"type": "string"}
    }
  }
}
