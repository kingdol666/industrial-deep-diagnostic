{
  "scene": {
    "name": "旋转压片机片剂质量诊断",
    "process_type": "rotary_tablet_compression",
    "production_goal": "生产质量合格的片剂（目标片重500mg，硬度>80N，脆碎度<1%，崩解<15min）",
    "equipment": [
      {
        "id": "rotary_press",
        "name": "旋转式压片机",
        "type": "rotary_tablet_press",
        "function": "通过旋转转塔上的多组冲模，将颗粒物料连续压缩成型"
      },
      {
        "id": "station_1",
        "name": "工位1",
        "type": "compression_station",
        "function": "使用冲模P101-7047进行片剂压缩"
      },
      {
        "id": "station_2",
        "name": "工位2",
        "type": "compression_station",
        "function": "使用冲模P102-9032进行片剂压缩"
      },
      {
        "id": "station_3",
        "name": "工位3",
        "type": "compression_station",
        "function": "使用冲模P103-1001进行片剂压缩"
      }
    ],
    "stages": [
      {
        "id": "fill",
        "name": "充填",
        "sequence": 1,
        "typical_duration": "连续（由转塔速度和充填轨长度决定）",
        "key_physics": "下冲头下降至充填深度，颗粒依靠重力流入模孔。充填深度和转塔速度共同决定片重。颗粒流动性和水分影响充填均匀性。"
      },
      {
        "id": "pre_compression",
        "name": "预压",
        "sequence": 2,
        "typical_duration": "~20-30ms",
        "key_physics": "上冲头轻压（~5-9kN），排除颗粒间空气，减少主压阶段空气裹入。影响片剂均匀性和层裂风险。"
      },
      {
        "id": "main_compression",
        "name": "主压",
        "sequence": 3,
        "typical_duration": "~20-30ms",
        "key_physics": "上冲头在压缩滚轮下施加最大力（~18-28kN），颗粒发生塑性变形和结合。压缩力、驻留时间和冲头接触面积决定片剂密度、硬度和厚度。冲头尖端球面半径影响单位面积比压。摩擦产生热量使压缩区升温。"
      },
      {
        "id": "ejection",
        "name": "出片",
        "sequence": 4,
        "typical_duration": "瞬时",
        "key_physics": "下冲头上升将片剂推出模孔。润滑剂减少出片力，防止片剂黏冲。"
      }
    ],
    "objectives": [
      "识别导致~25%缺陷率（B+C级）的根因",
      "区分工位/冲模间差异与全局过程参数变异的影响",
      "识别操作员补偿行为（压缩力上升是否为原因还是结果）",
      "排除混合水分随机波动等混杂因素"
    ]
  },
  "signals": {
    "inspection_signals": [
      {
        "name": "片重",
        "column": "tablet_weight_mg",
        "unit": "mg",
        "target": 500,
        "tolerance": null,
        "physical_interpretation": "单片重量，反映充填深度和颗粒堆密度的一致性"
      },
      {
        "name": "硬度",
        "column": "hardness_N",
        "unit": "N",
        "target": 80,
        "tolerance": null,
        "physical_interpretation": "片剂径向破碎力，主压缩合质量的直接反映"
      },
      {
        "name": "脆碎度",
        "column": "friability_pct",
        "unit": "%",
        "target": 1,
        "tolerance": null,
        "physical_interpretation": "片剂磨损损失百分比，反映表面机械强度"
      },
      {
        "name": "崩解时间",
        "column": "disintegration_time_min",
        "unit": "min",
        "target": 15,
        "tolerance": null,
        "physical_interpretation": "片剂在液体中完全崩解所需时间"
      },
      {
        "name": "厚度",
        "column": "thickness_mm",
        "unit": "mm",
        "target": null,
        "tolerance": null,
        "physical_interpretation": "片剂厚度，与压缩力和充填量相关"
      },
      {
        "name": "缺陷等级",
        "column": "defect_grade",
        "unit": "等级",
        "target": "A",
        "tolerance": null,
        "physical_interpretation": "综合质量评级：A=合格、B=边缘、C=不合格"
      }
    ],
    "process_parameters": [
      {
        "name": "主压压缩力",
        "column": "compression_force_kN",
        "unit": "kN",
        "normal_range": [18.06, 28.37],
        "physical_meaning": "主压阶段上冲头施加的最大力，决定片剂密度和硬度。观察到此值随生产进程呈上升趋势。",
        "control_type": "setpoint"
      },
      {
        "name": "预压压缩力",
        "column": "pre_compression_force_kN",
        "unit": "kN",
        "normal_range": [5.79, 9.47],
        "physical_meaning": "预压阶段上冲头施加的力，用于排出空气",
        "control_type": "setpoint"
      },
      {
        "name": "转塔速度",
        "column": "turret_speed_rpm",
        "unit": "rpm",
        "normal_range": [23.1, 31.5],
        "physical_meaning": "转塔旋转速度，决定充填时间、驻留时间和产能",
        "control_type": "setpoint"
      },
      {
        "name": "充填深度",
        "column": "fill_depth_mm",
        "unit": "mm",
        "normal_range": [9.98, 10.66],
        "physical_meaning": "下冲头下降深度，决定模孔容积，是控制片重的直接手段",
        "control_type": "setpoint"
      },
      {
        "name": "驻留时间",
        "column": "dwell_time_ms",
        "unit": "ms",
        "normal_range": [20.8, 29.4],
        "physical_meaning": "冲头在压缩滚轮下的接触时间，由转塔速度和滚轮弧长共同决定（测量值）",
        "control_type": "measurement"
      },
      {
        "name": "混合水分",
        "column": "blend_moisture_pct",
        "unit": "%",
        "normal_range": [0.80, 4.50],
        "physical_meaning": "颗粒物料含水量，影响颗粒的可压性和塑性变形能力。水分过高或过低都会影响片剂质量。",
        "control_type": "measurement"
      },
      {
        "name": "润滑剂水平",
        "column": "lubricant_level_pct",
        "unit": "%",
        "normal_range": [0.10, 2.00],
        "physical_meaning": "硬脂酸镁润滑剂在颗粒中的含量百分比，减少冲头与模壁的摩擦",
        "control_type": "setpoint"
      },
      {
        "name": "混合均匀度指数",
        "column": "blend_uniformity_index",
        "unit": "无量纲",
        "normal_range": [83.9, 99.7],
        "physical_meaning": "颗粒中药物和辅料分布均匀性的指标，数值越高越均匀，影响片剂含量均匀度",
        "control_type": "measurement"
      },
      {
        "name": "压缩区温度",
        "column": "compression_zone_temp_C",
        "unit": "°C",
        "normal_range": [21.7, 45.7],
        "physical_meaning": "冲模附近区域的温度传感器读数，受压缩摩擦热升温影响",
        "control_type": "measurement"
      },
      {
        "name": "环境温度",
        "column": "ambient_temp_C",
        "unit": "°C",
        "normal_range": [17.3, 28.3],
        "physical_meaning": "生产车间环境温度",
        "control_type": "measurement"
      },
      {
        "name": "环境湿度",
        "column": "ambient_humidity_pct",
        "unit": "%",
        "normal_range": [20.2, 70.2],
        "physical_meaning": "生产车间环境相对湿度，可能间接影响颗粒水分",
        "control_type": "measurement"
      }
    ],
    "control_variables": [
      {
        "name": "主压压缩力",
        "column": "compression_force_kN",
        "unit": "kN",
        "setpoint": "由操作员设定",
