  },
  "relationships": [
    {
      "from": "compression_force_kN",
      "to": "hardness_N",
      "type": "causal",
      "strength": "strong",
      "mechanism": "压缩力增大使颗粒塑性变形更充分，颗粒间结合更紧密，片剂硬度增加",
      "time_lag": "即时",
      "inferred": true
    },
    {
      "from": "compression_force_kN",
      "to": "thickness_mm",
      "type": "causal",
      "strength": "strong",
      "mechanism": "压缩力增大使片剂被压缩得更薄",
      "time_lag": "即时",
