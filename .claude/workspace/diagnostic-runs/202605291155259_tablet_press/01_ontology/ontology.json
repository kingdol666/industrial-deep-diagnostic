        "setpoint": "处方设定",
        "controlled_by": "预混合阶段添加"
      }
    ],
    "events": [
      {
        "name": "校准事件",
        "column": "event_type",
        "event_values": ["CALIBRATION"]
      },
      {
        "name": "物料事故",
        "column": "event_type",
        "event_values": ["MATERIAL_INCIDENT"]
      },
      {
        "name": "冲头修磨",
