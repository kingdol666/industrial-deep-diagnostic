      "time_lag": "事件后",
      "inferred": true
    }
  ],
  "confounders": [
    {
      "variable": "station / punch_serial",
      "why": "station与punch_serial完全相关（每站固定一把冲模），无法区分是工位差异还是冲模差异。所有缺陷集中在station 3/P103-1001。如果不按station分层，整体数据与过程参数的相关性会被掩盖。",
      "controlled": false
    },
    {
      "variable": "operator_id",
      "why": "操作员在三个工位交叉工作，但每个操作员在站3的时间比例不同，导致操作员间缺陷率差异是工位分配偏差的反映而非操作员能力差异。",
      "controlled": true
    },
    {
      "variable": "blend_moisture_pct",
      "why": "混合水分随机波动，同时影响所有工位的片剂质量。水分高时可能暂时提高硬度（掩盖站3的恶化），水分低时可能降低硬度（可能误判为冲头问题）。",
      "controlled": false
    },
    {
      "variable": "compression_force_kN",
      "why": "压缩力随时间上升（18→28kN）可能是操作员对质量下降的补偿行为（反向因果）。如果简单认为压缩力是独立自变量，会得出错误的因果结论。",
      "controlled": false
    },
    {
      "variable": "batch_day (time)",
      "why": "多变量同时随时间变化（压缩力、预压力、充填深度都随时间增大），需区分共同趋势与因果关系。",
      "controlled": false
    },
    {
      "variable": "event_effects",
      "why": "PUNCH_DRESSING（B0040后）、LUBRICANT_CHANGE（B0050后）等事件可能影响站3质量，需分段分析。",
      "controlled": false
    }
  ],
