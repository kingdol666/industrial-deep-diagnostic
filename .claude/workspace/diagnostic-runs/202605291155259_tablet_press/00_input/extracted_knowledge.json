  "variable_descriptions": {
    "compression_force_kN": {
      "physical_meaning": "主压阶段上冲头施加在颗粒物料上的最大压缩力",
      "unit": "kN",
      "normal_range": [18.06, 28.37],
      "control_type": "manual"
    },
    "pre_compression_force_kN": {
      "physical_meaning": "预压阶段上冲头施加的预压力，用于排除颗粒间空气",
      "unit": "kN",
      "normal_range": [5.79, 9.47],
      "control_type": "manual"
    },
    "turret_speed_rpm": {
      "physical_meaning": "转塔旋转速度，决定充填时间和驻留时间",
      "unit": "rpm",
      "normal_range": [23.1, 31.5],
      "control_type": "manual"
    },
    "fill_depth_mm": {
      "physical_meaning": "下冲头在充填轨中的下降深度，决定模孔容积和最终片重",
      "unit": "mm",
      "normal_range": [9.98, 10.66],
      "control_type": "manual"
    },
    "dwell_time_ms": {
      "physical_meaning": "冲头在压缩滚轮下的停留时间，影响塑性变形和颗粒结合",
      "unit": "ms",
      "normal_range": [20.8, 29.4],
      "control_type": "measurement"
    },
    "blend_moisture_pct": {
      "physical_meaning": "颗粒物料的水分含量，影响可压性和黏冲风险",
      "unit": "%",
      "normal_range": [0.80, 4.50],
      "control_type": "measurement"
    },
    "lubricant_level_pct": {
      "physical_meaning": "硬脂酸镁润滑剂含量百分比，减少冲模摩擦和出片力",
      "unit": "%",
      "normal_range": [0.10, 2.00],
      "control_type": "manual"
    },
    "blend_uniformity_index": {
      "physical_meaning": "混合均匀度指数，反映颗粒中药物和辅料分布的均匀程度",
      "unit": "无量纲",
      "normal_range": [83.9, 99.7],
      "control_type": "measurement"
    },
    "compression_zone_temp_C": {
      "physical_meaning": "压片区域（冲模附近）的温度，受压缩摩擦热和环境温度影响",
      "unit": "°C",
      "normal_range": [21.7, 45.7],
      "control_type": "measurement"
    },
    "ambient_temp_C": {
      "physical_meaning": "生产车间环境温度",
      "unit": "°C",
      "normal_range": [17.3, 28.3],
      "control_type": "measurement"
    },
    "ambient_humidity_pct": {
      "physical_meaning": "生产车间环境相对湿度",
      "unit": "%",
      "normal_range": [20.2, 70.2],
      "control_type": "measurement"
    },
    "tablet_weight_mg": {
      "physical_meaning": "单片的实际重量",
      "unit": "mg",
      "normal_range": [496.94, 512.34],
      "control_type": "measurement"
    },
    "hardness_N": {
      "physical_meaning": "片剂径向破碎力（硬度），反映片剂机械强度",
      "unit": "N",
      "normal_range": [56.17, 113.28],
      "control_type": "measurement"
    },
    "friability_pct": {
      "physical_meaning": "片剂脆碎度（磨损百分比），反映片剂表面抗磨损能力",
      "unit": "%",
      "normal_range": [0.10, 2.33],
      "control_type": "measurement"
    },
    "disintegration_time_min": {
      "physical_meaning": "片剂崩解时间，反映片剂在液体中崩解成颗粒的速度",
      "unit": "min",
      "normal_range": [5.03, 9.80],
      "control_type": "measurement"
    },
    "thickness_mm": {
      "physical_meaning": "片剂厚度",
      "unit": "mm",
      "normal_range": [4.93, 5.20],
      "control_type": "measurement"
    }
  },
