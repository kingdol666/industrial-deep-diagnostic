{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Column Schema — Paper Machine Headbox",
  "description": "列角色分类：target(质量目标), predictor(预测变量/过程参数), confounder(混淆变量), control(控制变量), metadata(元数据)",
  "scene": "paper_machine_headbox",
  "columns": {
    "metadata_columns": [
      {
        "column": "ts_dcs",
        "role": "metadata",
        "sub_role": "timestamp",
        "description": "DCS过程参数采样时间戳",
        "dtype": "datetime"
      },
      {
        "column": "ts_qcs",
        "role": "metadata",
        "sub_role": "timestamp",
        "description": "QCS质量参数采样时间戳",
        "dtype": "datetime"
      },
      {
        "column": "day",
        "role": "metadata",
        "sub_role": "temporal_index",
        "description": "生产天数编号(1-91)，从2025-10-01起算",
        "dtype": "float64"
      },
      {
        "column": "grade",
        "role": "metadata",
        "sub_role": "product_label",
        "description": "QCS质量检测时对应的纸品等级标签",
        "dtype": "category"
      }
    ],
    "confounder_columns": [
      {
        "column": "grade_running",
        "role": "confounder",
        "sub_role": "product_grade",
        "description": "当前运行的纸品等级。不同等级有不同的工艺设定点，是影响所有预测变量和目标变量的核心混淆变量。必须按等级分层分析",
        "dtype": "category",
        "levels": ["GSM80", "GSM100", "GSM120"],
        "confounding_mechanism": "不同纸品等级对应不同的操作区间(GSM120高压高速)→同时影响工艺参数水平和质量缺陷率→可能产生'高压导致高缺陷'的虚假因果关联"
      },
      {
        "column": "shift",
        "role": "confounder",
        "sub_role": "operator_shift",
        "description": "操作班次(1=白班, 2=夜班)。不同班次的操作人员可能有不同的调整策略和操作习惯",
        "dtype": "category",
        "levels": ["1", "2"],
        "confounding_mechanism": "班组差异可能影响参数设定策略和调整及时性→影响质量结果→可能掩盖真实物理因果"
      }
    ],
    "target_columns": [
      {
        "column": "defect_grade",
        "role": "target",
        "sub_role": "primary_quality_target",
        "description": "综合缺陷等级(A=优等品, B=合格品, C=次品)。三分类有序目标变量",
        "dtype": "category",
        "levels": ["A", "B", "C"],
        "distribution": {"A": 942, "B": 1320, "C": 978},
        "is_ordered": true,
        "objective": "最大化A级品率"
      },
      {
        "column": "cd_basis_weight_cv_pct",
        "role": "target",
        "sub_role": "secondary_quality_target",
        "description": "横幅定量变异系数。连续数值变量，CV越低表示横幅方向克重越均匀",
        "dtype": "float64",
        "unit": "%",
        "direction": "lower_is_better",
        "is_contributing_to_defect_grade": true
      },
      {
        "column": "formation_index",
        "role": "target",
        "sub_role": "secondary_quality_target",
        "description": "匀度指数。连续数值变量，指数越高表示纤维分布越均匀",
        "dtype": "float64",
        "unit": "index",
        "direction": "higher_is_better",
        "is_contributing_to_defect_grade": true
      },
      {
        "column": "ash_content_pct",
        "role": "target",
        "sub_role": "secondary_quality_target",
        "description": "灰分含量。连续数值变量，反映填料留着率",
        "dtype": "float64",
        "unit": "%",
        "direction": "within_spec",
        "is_contributing_to_defect_grade": true
      },
      {
        "column": "moisture_pct",
        "role": "target",
        "sub_role": "secondary_quality_target",
        "description": "水分含量。本数据集中几乎恒定(mean=3.0, std≈0)，诊断价值有限",
        "dtype": "float64",
        "unit": "%",
        "direction": "within_spec",
        "is_contributing_to_defect_grade": true,
        "data_quality_note": "近乎常量，方差极小，可能无法提供足够的统计信号"
      },
      {
        "column": "strength_rel_pct",
        "role": "target",
        "sub_role": "secondary_quality_target",
        "description": "相对强度。连续数值变量，受纤维取向(MD/CD比)和纤维结合力影响",
        "dtype": "float64",
        "unit": "%",
        "direction": "higher_is_better",
        "is_contributing_to_defect_grade": true
      }
    ],
    "predictor_columns": [
      {
        "column": "headbox_pressure_kPa",
        "role": "predictor",
        "sub_role": "key_process_variable",
        "description": "流浆箱总压头。决定浆流喷射速度的核心变量。波动直接导致MD定量变化",
        "dtype": "float64",
        "unit": "kPa",
        "quality_notes": ["min=0值可能为停机期间，需过滤", "有25个缺失值"]
      },
      {
        "column": "approach_flow_lpm",
        "role": "predictor",
        "sub_role": "key_process_variable",
        "description": "进入流浆箱的纸浆体积流量。与浆速和堰板开口共同决定定量",
        "dtype": "float64",
        "unit": "L/min",
        "quality_notes": ["有3个缺失值"]
      },
      {
        "column": "fan_pump_speed_rpm",
        "role": "predictor",
        "sub_role": "control_actuator",
        "description": "冲浆泵转速。调节上浆流量和流浆箱压力的执行机构",
        "dtype": "float64",
        "unit": "RPM"
      },
      {
        "column": "white_water_consistency_pct",
        "role": "predictor",
        "sub_role": "retention_indicator",
        "description": "白水浓度。留着率的间接反馈指标",
        "dtype": "float64",
        "unit": "%"
      },
      {
        "column": "retention_aid_dosage_ppm",
        "role": "predictor",
        "sub_role": "chemical_control",
        "description": "助留剂添加量。影响留着率和匀度的关键化学品参数",
        "dtype": "float64",
        "unit": "ppm",
        "also_control": true
      },
      {
        "column": "slice_opening_mm",
        "role": "predictor",
        "sub_role": "mechanical_control",
        "description": "堰板开口宽度。控制浆流厚度和横幅定量分布",
        "dtype": "float64",
        "unit": "mm",
        "also_control": true
      },
      {
        "column": "machine_speed_mmin",
        "role": "predictor",
        "sub_role": "speed_setting",
        "description": "成形网运行线速度。与浆速的比值决定纤维取向和匀度",
        "dtype": "float64",
        "unit": "m/min",
        "quality_notes": ["min=0值可能为停机期间，需过滤", "有4个缺失值"],
        "also_control": true
      },
      {
        "column": "stock_temp_C",
        "role": "predictor",
        "sub_role": "material_property",
        "description": "浆料温度。影响水黏度和浆料流动性",
        "dtype": "float64",
        "unit": "°C",
        "quality_notes": ["min=0值可能为缺失数据，需过滤", "有2个缺失值"]
      },
      {
        "column": "jet_to_wire_ratio",
        "role": "predictor",
        "sub_role": "derived_process_variable",
        "description": "浆网速比(rush/drag ratio)。浆流喷射速度与网速之比，控制匀度和纤维取向的核心变量",
        "dtype": "float64",
        "unit": "ratio"
      },
      {
        "column": "vacuum_pump1_kPa",
        "role": "predictor",
        "sub_role": "dewatering_parameter",
        "description": "真空泵1(前段)真空度。控制初始脱水速率",
        "dtype": "float64",
        "unit": "kPa"
      },
      {
        "column": "vacuum_pump2_kPa",
        "role": "predictor",
        "sub_role": "dewatering_parameter",
        "description": "真空泵2(中后段)真空度。控制后期脱水程度。皮带更换事件可能影响其性能",
        "dtype": "float64",
        "unit": "kPa",
        "quality_notes": ["有极端离群值(min=-166.9, max=404.6)，需>3 IQR过滤", "有5个缺失值"]
      }
    ]
  },
  "data_quality_summary": {
    "total_rows": 3240,
    "missing_values": {
      "headbox_pressure_kPa": 25,
      "approach_flow_lpm": 3,
      "machine_speed_mmin": 4,
      "stock_temp_C": 2,
      "vacuum_pump2_kPa": 5,
      "moisture_pct": 2
    },
    "zero_valued_columns_to_filter": ["headbox_pressure_kPa", "machine_speed_mmin", "stock_temp_C"],
    "extreme_outlier_column": "vacuum_pump2_kPa",
    "near_constant_column": "moisture_pct",
    "sampling_mismatch": "DCS采样间隔~2min，QCS采样间隔~40min(非均匀)。合并数据已按QCS时间戳对齐",
    "sorting_status": "需由stats.mjs自动验证是否按时间排序"
  },
  "analysis_constraints": {
    "must_stratify_by": ["grade_running"],
    "should_stratify_by": ["shift"],
    "confounders_to_control": [
      {"column": "grade_running", "method": "stratified_analysis"},
      {"column": "shift", "method": "subgroup_comparison"},
      {"column": "day", "method": "detrending"}
    ],
    "exclusion_rules": [
      "machine_speed_mmin == 0 (停机期间)",
      "headbox_pressure_kPa == 0 (可能停机或传感器故障)",
      "stock_temp_C == 0 (可能缺失数据)",
      "vacuum_pump2_kPa 离群值 > 3 IQR"
    ]
  }
}
