{
  "scene": {
    "name": "纸机流浆箱质量诊断",
    "process_type": "continuous_paper_manufacturing_headbox",
    "production_goal": "生产三种纸品等级（GSM80/GSM100/GSM120），目标A级品率>60%，实际仅29%",
    "equipment": [
      {
        "id": "HEADBOX-01",
        "name": "水力式流浆箱",
        "type": "hydraulic_headbox",
        "function": "将纸浆悬浮液均匀分布到成形网上，通过堰板喷出均匀浆流",
        "location": "湿部 / 成形部之前"
      },
      {
        "id": "FAN-PUMP-01",
        "name": "冲浆泵",
        "type": "centrifugal_fan_pump",
        "function": "将稀释后的纸浆输送至流浆箱，提供流浆箱所需压力和流量",
        "location": "湿部 / 流浆箱上游"
      },
      {
        "id": "SLICE-01",
        "name": "堰板（唇板）",
        "type": "adjustable_slice_lip",
        "function": "控制浆流喷出厚度和速度，调节横幅定量分布",
        "location": "流浆箱出口"
      },
      {
        "id": "VAC-PUMP-01",
        "name": "真空泵 #1",
        "type": "liquid_ring_vacuum_pump",
        "function": "成形网部脱水真空源，控制初始脱水速率",
        "location": "湿部 / 成形网下方"
      },
      {
        "id": "VAC-PUMP-02",
        "name": "真空泵 #2",
        "type": "liquid_ring_vacuum_pump",
        "function": "辅助脱水真空源，影响纸页干度和强度",
        "location": "湿部 / 成形网中后段"
      },
      {
        "id": "RET-AID-01",
        "name": "助留剂添加系统",
        "type": "chemical_dosing_system",
        "function": "向纸浆中定量添加助留剂，提高细小纤维和填料的留着率",
        "location": "湿部 / 冲浆泵入口"
      },
      {
        "id": "WIRE-01",
        "name": "成形网",
        "type": "fourdrinier_wire",
        "function": "纸浆脱水成形，纤维交织形成湿纸页",
        "location": "湿部 / 流浆箱下游"
      }
    ],
    "stages": [
      {
        "id": "S1",
        "name": "浆料制备与输送",
        "sequence": 1,
        "typical_duration": "连续",
        "key_physics": "冲浆泵将稀释浆料加压输送至流浆箱，浆料温度影响黏度和流动性",
        "key_parameters": ["fan_pump_speed_rpm", "approach_flow_lpm", "stock_temp_C", "white_water_consistency_pct"]
      },
      {
        "id": "S2",
        "name": "流浆箱分配与整流",
        "sequence": 2,
        "typical_duration": "连续",
        "key_physics": "流浆箱内压力转化为浆流动能，通过整流元件消除大尺度湍流，产生微湍流以分散纤维絮聚",
        "key_parameters": ["headbox_pressure_kPa", "retention_aid_dosage_ppm"]
      },
      {
        "id": "S3",
        "name": "堰板喷射与着网",
        "sequence": 3,
        "typical_duration": "连续",
        "key_physics": "浆流从堰板喷出，jet-to-wire ratio决定剪切力——ratio=1.0时无明显剪切，偏离1.0产生剪切力分散纤维絮聚但影响纤维取向",
        "key_parameters": ["slice_opening_mm", "machine_speed_mmin", "jet_to_wire_ratio"]
      },
      {
        "id": "S4",
        "name": "网部脱水成形",
        "sequence": 4,
        "typical_duration": "连续",
        "key_physics": "真空泵提供负压驱动力，水分从纸页中脱除，脱水速率影响纤维分布和纸页紧度",
        "key_parameters": ["vacuum_pump1_kPa", "vacuum_pump2_kPa"]
      }
    ],
    "objectives": [
      "诊断导致B/C级品率高达71%的根因",
      "区分工艺参数偏差、设备老化和操作差异对质量的影响",
      "分析三种纸品等级（GSM80/100/120）间质量差异的结构性原因",
      "评估频繁换产（619次等级切换）对质量稳定性的影响",
      "量化四个显著事件（真空泵皮带更换、压力变送器校准、BOIL_OUT清洗、断纸）对质量的冲击"
    ]
  },
  "signals": {
    "inspection_signals": [
      {
        "name": "缺陷等级",
        "column": "defect_grade",
        "unit": "category",
        "role": "target",
        "physical_meaning": "综合质量评级，A=优等品，B=合格品，C=次品。基于横幅定量变异、匀度、灰分、水分、强度等多项指标综合判定",
        "physical_meaning_confidence": "KNOWN",
        "control_type": "measurement",
        "target": null,
        "tolerance": null,
        "normal_range": null,
        "stage_ref": "S4"
      },
      {
        "name": "横幅定量变异系数",
        "column": "cd_basis_weight_cv_pct",
        "unit": "%",
        "role": "target",
        "physical_meaning": "纸页横幅方向克重分布的变异系数，反映横幅定量均匀性。CV越高表示横幅方向厚薄不均越严重",
        "physical_meaning_confidence": "KNOWN",
        "control_type": "measurement",
        "target": null,
        "tolerance": null,
        "normal_range": [0.15, 2.0],
        "stage_ref": "S3"
      },
      {
        "name": "匀度指数",
        "column": "formation_index",
        "unit": "index",
        "role": "target",
        "physical_meaning": "纸页纤维分布均匀程度的综合指标。指数越高表示纤维分布越均匀（匀度越好），指数越低表示存在絮聚或云状不均匀",
        "physical_meaning_confidence": "KNOWN",
        "control_type": "measurement",
        "target": null,
        "tolerance": null,
        "normal_range": [7.0, 9.5],
        "stage_ref": "S2"
      },
      {
        "name": "灰分含量",
        "column": "ash_content_pct",
        "unit": "%",
        "role": "target",
        "physical_meaning": "纸页中无机填料和矿物质残留量占总质量的百分比，反映填料留着率和成纸功能特性",
        "physical_meaning_confidence": "KNOWN",
        "control_type": "measurement",
        "target": null,
        "tolerance": null,
        "normal_range": [20.0, 28.0],
        "stage_ref": "S4"
      },
      {
        "name": "水分含量",
        "column": "moisture_pct",
        "unit": "%",
        "role": "target",
        "physical_meaning": "成纸残余含水量，影响纸页物理强度和尺寸稳定性。本数据集中该参数几乎恒定(mean=3.0, std≈0)，诊断价值有限",
        "physical_meaning_confidence": "KNOWN",
        "control_type": "measurement",
        "target": 3.0,
        "tolerance": 0.5,
        "normal_range": [2.5, 3.5],
        "stage_ref": "S4"
      },
      {
        "name": "相对强度",
        "column": "strength_rel_pct",
        "unit": "%",
        "role": "target",
        "physical_meaning": "纸页抗张强度相对标准值的百分比。受纤维取向(MD/CD比)、纤维间结合力和纤维本身强度共同影响",
        "physical_meaning_confidence": "KNOWN",
        "control_type": "measurement",
        "target": 100.0,
        "tolerance": null,
        "normal_range": [95.0, 105.0],
        "stage_ref": "S4"
      }
    ],
    "process_parameters": [
      {
        "name": "流浆箱压力",
        "column": "headbox_pressure_kPa",
        "unit": "kPa",
        "role": "predictor",
        "physical_meaning": "流浆箱内总压头，根据Vj=Cv*sqrt(2g*H_T)决定浆流喷出速度。压力波动直接导致MD方向定量波动(±2%速度扰动→±7%定量变化)",
        "physical_meaning_confidence": "KNOWN",
        "control_type": "measurement",
        "target": null,
        "normal_range": [13.5, 39.8],
        "controlled_by": "fan_pump_speed_rpm",
        "equipment_ref": "HEADBOX-01",
        "stage_ref": "S2"
      },
      {
        "name": "上浆流量",
        "column": "approach_flow_lpm",
        "unit": "L/min",
        "role": "predictor",
        "physical_meaning": "进入流浆箱的纸浆体积流量，与浆速和堰板开口相关。流量=面积×速度，流量不稳定导致上浆压力波动和横幅定量变化",
        "physical_meaning_confidence": "KNOWN",
        "control_type": "measurement",
        "target": null,
        "normal_range": [3705, 5412],
        "controlled_by": "fan_pump_speed_rpm",
        "equipment_ref": "FAN-PUMP-01",
        "stage_ref": "S1"
      },
      {
        "name": "冲浆泵转速",
        "column": "fan_pump_speed_rpm",
        "unit": "RPM",
        "role": "predictor",
        "physical_meaning": "冲浆泵驱动电机的转速，是调节上浆流量和流浆箱压力的主要手段。转速波动通过泵特性曲线影响出口压力和流量",
        "physical_meaning_confidence": "KNOWN",
        "control_type": "output",
        "target": null,
        "normal_range": [864, 956],
        "controlled_by": "operator_or_DCS",
        "equipment_ref": "FAN-PUMP-01",
        "stage_ref": "S1"
      },
      {
        "name": "白水浓度",
        "column": "white_water_consistency_pct",
        "unit": "%",
        "role": "predictor",
        "physical_meaning": "成形网滤出白水中的纤维和填料含量，是留着率的间接反馈指标。白水浓度越高→留着率越低→纤维和填料流失越严重",
        "physical_meaning_confidence": "KNOWN",
        "control_type": "measurement",
        "target": null,
        "normal_range": [0.7, 1.3],
        "controlled_by": "retention_aid_dosage_ppm",
        "equipment_ref": "WIRE-01",
        "stage_ref": "S4"
      },
      {
        "name": "助留剂用量",
        "column": "retention_aid_dosage_ppm",
        "unit": "ppm",
        "role": "predictor",
        "physical_meaning": "每百万份浆料中添加的助留剂量。助留剂通过电荷中和和桥联作用使细小纤维和填料絮聚留在纸页中。过量会导致过度絮聚→匀度变差",
        "physical_meaning_confidence": "KNOWN",
        "control_type": "setpoint",
        "target": null,
        "normal_range": [154, 299],
        "controlled_by": "DCS_retention_controller",
        "equipment_ref": "RET-AID-01",
        "stage_ref": "S2"
      },
      {
        "name": "堰板开口",
        "column": "slice_opening_mm",
        "unit": "mm",
        "role": "predictor",
        "physical_meaning": "流浆箱唇板缝隙宽度，控制浆流喷出厚度。堰板开口×浆速×浓度=定量(单位面积克重)。开口不均匀导致横幅定量条纹",
        "physical_meaning_confidence": "KNOWN",
        "control_type": "setpoint",
        "target": null,
        "normal_range": [6.6, 13.2],
        "controlled_by": "operator_or_DCS",
        "equipment_ref": "SLICE-01",
        "stage_ref": "S3"
      },
      {
        "name": "纸机速度",
        "column": "machine_speed_mmin",
        "unit": "m/min",
        "role": "predictor",
        "physical_meaning": "成形网运行线速度，直接控制纸页在网部的牵引拉伸。速度与浆速的比值(jet-to-wire ratio)决定纤维取向和匀度",
        "physical_meaning_confidence": "KNOWN",
        "control_type": "setpoint",
        "target": null,
        "normal_range": [1267, 1764],
        "controlled_by": "operator_or_DCS",
        "equipment_ref": "WIRE-01",
        "stage_ref": "S3"
      },
      {
        "name": "浆料温度",
        "column": "stock_temp_C",
        "unit": "°C",
        "role": "predictor",
        "physical_meaning": "纸浆悬浮液温度。温度影响水的黏度——温度升高→黏度降低→浆料流动性改善、脱水速度加快。温度异常波动可能反映白水循环系统问题",
        "physical_meaning_confidence": "KNOWN",
        "control_type": "measurement",
        "target": null,
        "normal_range": [35, 50],
        "controlled_by": null,
        "stage_ref": "S1"
      },
      {
        "name": "浆网速比",
        "column": "jet_to_wire_ratio",
        "unit": "ratio",
        "role": "predictor",
        "physical_meaning": "浆流喷射速度与成形网速度之比(rush/drag ratio)。=1.0时无剪切，匀度最差(纤维絮聚无法被破坏)；偏离1.0产生剪切力改善匀度但增强纤维MD取向，影响MD/CD强度比。典型运行范围0.97-1.05",
        "physical_meaning_confidence": "KNOWN",
        "control_type": "measurement",
        "target": null,
        "normal_range": [0.97, 1.05],
        "controlled_by": "headbox_pressure_and_machine_speed",
        "stage_ref": "S3"
      },
      {
        "name": "真空泵1真空度",
        "column": "vacuum_pump1_kPa",
        "unit": "kPa",
        "role": "predictor",
        "physical_meaning": "成形网前段真空脱水负压值，控制初始脱水速率。真空度过高→初始脱水过快→纤维“封闭”过早→后续脱水困难、纸页蓬松度下降",
        "physical_meaning_confidence": "KNOWN",
        "control_type": "measurement",
        "target": null,
        "normal_range": [40, 62],
        "controlled_by": null,
        "equipment_ref": "VAC-PUMP-01",
        "stage_ref": "S4"
      },
      {
        "name": "真空泵2真空度",
        "column": "vacuum_pump2_kPa",
        "unit": "kPa",
        "role": "predictor",
        "physical_meaning": "成形网中后段真空脱水负压值，控制后期脱水程度。数据质量差（极端离群值min=-166.9, max=404.6），需剔除异常后进行诊断。期间发生过真空泵2皮带更换事件",
        "physical_meaning_confidence": "KNOWN",
        "control_type": "measurement",
        "target": null,
        "normal_range": [35, 65],
        "controlled_by": null,
        "equipment_ref": "VAC-PUMP-02",
        "stage_ref": "S4"
      }
    ],
