{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.org/schemas/experiment_record.schema.json",
  "title": "Experiment Record",
  "description": "A single extracted experiment record from a scientific paper",
  "type": "object",
  "required": ["experiment_id", "source_id", "paper_title", "year"],
  "properties": {
    "experiment_id": {
      "type": "string",
      "pattern": "^SRC_\\d+_E\\d+$",
      "description": "Unique experiment identifier, format: SRC_{source_number}_E{experiment_number}"
    },
    "source_id": {
      "type": "string",
      "pattern": "^SRC_\\d+$",
      "description": "Reference to the source paper"
    },
    "paper_title": { "type": "string" },
    "year": { "type": "integer", "minimum": 1900, "maximum": 2030 },
    "source_doi": { "type": ["string", "null"] },
    "sample_name": { "type": ["string", "null"] },
    "material_system": { "type": ["string", "null"] },
    "material_grade": { "type": ["string", "null"] },
    "additive": { "type": ["string", "null"] },
    "additive_concentration": { "type": ["number", "null"] },
    "additive_concentration_unit": { "type": ["string", "null"] },
    "additive_subtype": { "type": ["string", "null"] },
    "plasticizer": { "type": ["string", "null"] },
    "plasticizer_concentration": { "type": ["number", "null"] },
    "plasticizer_concentration_unit": { "type": ["string", "null"] },
    "crosslinker": { "type": ["string", "null"] },
    "crosslinker_concentration": { "type": ["number", "null"] },
    "crosslinker_concentration_unit": { "type": ["string", "null"] },
    "solvent": { "type": ["string", "null"] },
    "solution_concentration": { "type": ["number", "null"] },
    "solution_concentration_unit": { "type": ["string", "null"] },
    "film_preparation_method": { "type": ["string", "null"] },
    "drying_temperature": { "type": ["number", "null"] },
    "drying_temperature_unit": { "type": ["string", "null"] },
    "drying_time": { "type": ["number", "null"] },
    "drying_time_unit": { "type": ["string", "null"] },
    "heat_treatment_temperature": { "type": ["number", "null"] },
    "heat_treatment_temperature_unit": { "type": ["string", "null"] },
    "heat_treatment_time": { "type": ["number", "null"] },
    "heat_treatment_time_unit": { "type": ["string", "null"] },
    "stretching_ratio": { "type": ["number", "null"] },
    "stretching_temperature": { "type": ["number", "null"] },
    "stretching_temperature_unit": { "type": ["string", "null"] },
    "film_thickness": { "type": ["number", "null"] },
    "film_thickness_unit": { "type": ["string", "null"] },
    "instrument": { "type": ["string", "null"] },
    "measured_property": { "type": ["string", "null"] },
    "measured_value": { "type": ["number", "null"] },
    "measured_unit": { "type": ["string", "null"] },
    "wavelength": { "type": ["number", "null"] },
    "wavelength_unit": { "type": ["string", "null"] },
    "measured_property_2": { "type": ["string", "null"] },
    "measured_value_2": { "type": ["number", "null"] },
    "measured_unit_2": { "type": ["string", "null"] },
    "measured_property_3": { "type": ["string", "null"] },
    "measured_value_3": { "type": ["number", "null"] },
    "measured_unit_3": { "type": ["string", "null"] },
    "measured_property_4": { "type": ["string", "null"] },
    "measured_value_4": { "type": ["number", "null"] },
    "measured_unit_4": { "type": ["string", "null"] },
    "measured_property_5": { "type": ["string", "null"] },
    "measured_value_5": { "type": ["number", "null"] },
    "measured_unit_5": { "type": ["string", "null"] },
    "comparison_baseline": { "type": ["string", "null"] },
    "result_direction": {
      "type": ["string", "null"],
      "enum": ["improved", "degraded", "no_change", "inconclusive", null]
    },
    "error_type": {
      "type": ["string", "null"],
      "enum": ["std_dev", "std_error", "confidence_interval", "range", "iqr", null]
    },
    "error_value": { "type": ["number", "null"] },
    "value_type": {
      "type": ["string", "null"],
      "enum": ["exact", "range_midpoint", "approximate", "lower_bound", "upper_bound", null]
    },
    "value_min": { "type": ["number", "null"] },
    "value_max": { "type": ["number", "null"] },
    "conclusion_author": { "type": ["string", "null"] },
    "alternative_values": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "field": { "type": "string" },
          "value": {},
          "unit": { "type": "string" },
          "source": { "type": "string" }
        }
      }
    },
    "source_page": { "type": ["integer", "null"], "minimum": 0 },
    "source_location": { "type": ["string", "null"] },
    "source_snippet": { "type": ["string", "null"] },
    "extraction_method": {
      "type": ["string", "null"],
      "enum": ["table_parse", "text_regex", "llm_extraction", "caption_parse", "graph_digitize", "inferred_context", "cross_reference", null]
    },
    "confidence": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0
    },
    "record_confidence": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0,
      "description": "Minimum confidence across all populated fields in this record"
    },
    "notes": { "type": ["string", "null"] },
    "ambiguous_naming": { "type": "boolean", "default": false },
    "secondary_source": { "type": "boolean", "default": false },
    "preparation_only": { "type": "boolean", "default": false },
    "name_original": { "type": ["string", "null"] },
    "name_canonical": { "type": ["string", "null"] },
    "metadata": {
      "type": "object",
      "required": ["extraction_date", "skill_version"],
      "properties": {
        "extraction_date": { "type": "string", "format": "date" },
        "skill_version": { "type": "string" },
        "domain": { "type": "string" }
      }
    }
  }
}