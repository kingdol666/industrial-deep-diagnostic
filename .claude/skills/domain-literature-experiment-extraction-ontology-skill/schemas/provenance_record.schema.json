{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.org/schemas/provenance_record.schema.json",
  "title": "Provenance Record",
  "description": "Field-level provenance trace for an extracted experiment record",
  "type": "object",
  "required": ["experiment_id", "source_id", "fields"],
  "properties": {
    "experiment_id": {
      "type": "string",
      "pattern": "^SRC_\\d+_E\\d+$"
    },
    "source_id": {
      "type": "string",
      "pattern": "^SRC_\\d+$"
    },
    "source_title": { "type": "string" },
    "source_authors": {
      "type": "array",
      "items": { "type": "string" }
    },
    "source_year": { "type": "integer" },
    "source_doi": { "type": ["string", "null"] },
    "extraction_date": { "type": "string", "format": "date" },
    "extraction_agent": { "type": "string" },
    "fields": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["confidence", "extraction_method"],
        "properties": {
          "source_location": { "type": ["string", "null"] },
          "source_page": { "type": ["integer", "null"] },
          "source_snippet": { "type": ["string", "null"] },
          "extraction_method": {
            "type": "string",
            "enum": ["table_parse", "text_regex", "llm_extraction", "caption_parse", "graph_digitize", "inferred_context", "cross_reference"]
          },
          "confidence": {
            "type": "number",
            "minimum": 0.0,
            "maximum": 1.0
          },
          "value_original": {},
          "value_normalized": {},
          "unit_original": { "type": ["string", "null"] },
          "unit_normalized": { "type": ["string", "null"] },
          "assumptions": {
            "type": "array",
            "items": { "type": "string" }
          },
          "conversion_applied": { "type": ["string", "null"] }
        }
      }
    },
    "record_confidence": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0,
      "description": "Minimum field-level confidence"
    },
    "low_confidence_fields": {
      "type": "array",
      "items": { "type": "string" },
      "description": "List of field names with confidence < 0.5"
    }
  }
}