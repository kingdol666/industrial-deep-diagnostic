{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.org/schemas/extraction_config.schema.json",
  "title": "Extraction Configuration",
  "description": "User-customizable schema for experiment data extraction fields",
  "type": "object",
  "required": ["domain", "fields"],
  "properties": {
    "domain": { "type": "string" },
    "version": { "type": "string" },
    "fields": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["field_name", "data_type"],
        "properties": {
          "field_name": { "type": "string" },
          "data_type": {
            "type": "string",
            "enum": ["string", "number", "integer", "boolean", "enum"]
          },
          "required": { "type": "boolean", "default": false },
          "description": { "type": "string" },
          "allowed_values": {
            "type": "array",
            "items": { "type": "string" }
          },
          "unit_field": { "type": "string" },
          "table_header_keywords": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Keywords to match table column headers to this field"
          },
          "text_patterns": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Regex/text patterns to extract this field from narrative text"
          },
          "canonical_unit": { "type": "string" }
        }
      }
    }
  }
}