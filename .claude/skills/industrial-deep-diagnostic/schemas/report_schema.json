{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Report Schema v6.0",
  "description": "Schema for validating v6.0 diagnostic report structure. Includes Competing Hypotheses Disclosure, Statistical Validation section, Hallucination Audit Log, and Discriminability Matrix.",
  "type": "object",
  "required": ["sections", "metadata"],
  "properties": {
    "metadata": {
      "type": "object",
      "required": ["scene_name", "run_id", "date"],
      "properties": {
        "scene_name": {"type": "string"},
        "batch_id": {"type": "string"},
        "run_id": {"type": "string"},
        "date": {"type": "string", "format": "date"},
        "judge_score": {"type": "integer", "minimum": 0, "maximum": 100},
        "judge_verdict": {"type": "string"},
        "diagnosis_type": {"type": "string", "enum": ["DETERMINED", "COMPETING_SET", "NEEDS_DATA"]},
        "analyst": {"type": "string"}
      }
    },
    "sections": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title", "number"],
        "properties": {
          "title": {"type": "string"},
          "number": {"type": "integer"},
          "required": {"type": "boolean", "default": true},
          "v6_required": {"type": "boolean", "description": "Whether this section is mandatory in v6.0"},
          "subsections": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "title": {"type": "string"},
                "number": {"type": "string"}
              }
            }
          }
        }
      }
    },
    "v6_mandatory_sections": {
      "type": "object",
      "description": "v6.0: Sections that MUST appear in every report",
      "properties": {
        "executive_summary": {"type": "boolean", "const": true},
        "reasoning_overview": {"type": "boolean", "const": true},
        "visualization_evidence_per_figure": {"type": "boolean", "const": true},
        "diagnostic_findings": {"type": "boolean", "const": true},
        "statistical_validation_and_confidence": {"type": "boolean", "const": true},
        "competing_hypotheses_disclosure": {"type": "boolean", "const": true},
        "limitations_and_uncertainty": {"type": "boolean", "const": true},
        "recommended_actions": {"type": "boolean", "const": true},
        "appendix_hallucination_audit_log": {"type": "boolean", "const": true},
        "appendix_discriminability_matrix": {"type": "boolean", "const": true}
      }
    },
    "validation_rules": {
      "type": "object",
      "properties": {
        "must_cite_evidence": {"type": "boolean", "default": true},
        "must_distinguish_observed_from_inferred": {"type": "boolean", "default": true, "description": "v6.0: [OBSERVED] vs [INFERRED] markers required"},
        "must_include_uncertainty_decomposition": {"type": "boolean", "default": true, "description": "v6.0: Aleatory vs epistemic vs model uncertainty"},
        "must_use_language_templates": {"type": "boolean", "default": true},
        "external_knowledge_must_be_labeled": {"type": "boolean", "default": true},
        "must_disclose_competing_hypotheses": {"type": "boolean", "default": true, "description": "v6.0: COMPETING_SET must be transparently disclosed"},
        "must_include_discrimination_conditions": {"type": "boolean", "default": true, "description": "v6.0: What data would resolve ambiguity"},
        "must_embed_all_figures": {"type": "boolean", "default": true, "description": "v6.0: Every figure from plot_manifest.json must be embedded"}
      }
    }
  }
}
