{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "fusion_cross_validation_schema.json",
  "title": "Fusion Cross-Validation Matrix",
  "description": "Cross-validation results between Statistical and Physical Engine findings.",
  "type": "object",
  "required": ["engine", "timestamp", "run_id", "cross_validation_matrix", "fusion_verdicts", "data_gaps_identified", "fusion_bottom_line"],
  "properties": {
    "engine": { "const": "fusion" },
    "timestamp": { "type": "string", "format": "date-time" },
    "run_id": { "type": "string" },
    "cross_validation_matrix": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "fusion_result", "fusion_confidence", "fusion_reasoning"],
        "properties": {
          "id": { "type": "string", "pattern": "^XV-\\d{3}$" },
          "statistical_finding": { "type": "string" },
          "physical_finding": { "type": "string" },
          "fusion_result": {
            "type": "string",
            "enum": [
              "DOUBLE_CONFIRMED_EXCLUSION",
              "CONVERGENCE",
              "CONVERGENCE_WEAK",
              "STATISTICAL_ONLY_NO_PHYSICS",
              "PHYSICAL_ONLY_NO_STATISTICS",
              "CONFLICT_PHYSICS_OVERRIDES",
              "CONFLICT_UNRESOLVED",
              "BOTH_REJECTED",
              "STATISTICAL_REJECTION_PHYSICAL_CAVEAT"
            ]
          },
          "fusion_confidence": { "type": "integer", "minimum": 0, "maximum": 100 },
          "fusion_reasoning": { "type": "string" },
          "resolution_action": { "type": "string" }
        }
      }
    },
    "fusion_verdicts": {
      "type": "object",
      "properties": {
        "double_confirmed": { "type": "array", "items": { "type": "string" } },
        "convergence": { "type": "array", "items": { "type": "string" } },
        "statistical_only_no_physics": { "type": "array", "items": { "type": "string" } },
        "physical_only_no_statistics": { "type": "array", "items": { "type": "string" } },
        "conflict": { "type": "array", "items": { "type": "string" } },
        "both_rejected": { "type": "array", "items": { "type": "string" } }
      }
    },
    "data_gaps_identified": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "gap": { "type": "string" },
          "blocks_verification_of": { "type": "string" },
          "impact": { "type": "string" },
          "priority": { "type": "string" }
        }
      }
    },
    "fusion_bottom_line": { "type": "string" }
  }
}
