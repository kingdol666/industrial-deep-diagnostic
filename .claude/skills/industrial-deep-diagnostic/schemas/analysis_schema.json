{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Analysis Schema v6.0",
  "description": "Schema for v6.0 diagnostic analysis results (Competing Hypotheses Protocol). Used as supplementary validation for feature_summary.json integration.",
  "type": "object",
  "required": ["run_id", "analysis_time", "data_characterization", "statistical_findings", "hypotheses", "conclusion"],
  "properties": {
    "run_id": {"type": "string"},
    "analysis_time": {"type": "string", "format": "date-time"},
    "data_characterization": {
      "type": "object",
      "required": ["time_sorted", "product_groups_present", "dimensionality"],
      "properties": {
        "time_sorted": {"type": "boolean"},
        "product_groups_present": {"type": "boolean"},
        "dimensionality": {"type": "string", "enum": ["1d_scalar", "multi_axis", "2d_profile", "batch_event", "product_grouped", "spectral", "mixed"]},
        "row_count": {"type": "integer"},
        "column_count": {"type": "integer"},
        "time_range": {
          "type": "object",
          "properties": {
            "start": {"type": "string", "format": "date-time"},
            "end": {"type": "string", "format": "date-time"}
          }
        }
      }
    },
    "statistical_findings": {
      "type": "object",
      "properties": {
        "top_correlations": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "parameter": {"type": "string"},
              "defect": {"type": "string"},
              "pearson_r": {"type": "number", "minimum": -1, "maximum": 1},
              "spearman_rho": {"type": "number", "minimum": -1, "maximum": 1},
              "detrended_r": {"type": "number", "minimum": -1, "maximum": 1},
              "mutual_information": {"type": "number"},
              "granger_p_value": {"type": "number"}
            }
          }
        },
        "validation_flags": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "check": {"type": "string"},
              "severity": {"type": "string", "enum": ["CRITICAL", "SERIOUS", "MODERATE", "INFO"]},
              "affected_relationships": {"type": "array", "items": {"type": "string"}}
            }
          }
        }
      }
    },
    "hypotheses": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "mechanism_class", "confidence"],
        "properties": {
          "id": {"type": "string", "pattern": "^H[0-9]+$"},
          "name": {"type": "string"},
          "mechanism_class": {"type": "string", "enum": ["WEAR", "DRIFT", "CONTAMINATION", "OPERATION", "ENVIRONMENT", "INTERACTION"]},
          "chain_quality": {"type": "string", "enum": ["ACTIONABLE_HYPOTHESIS", "PLAUSIBLE_HYPOTHESIS", "RESEARCH_QUESTION"]},
          "confidence": {"type": "integer", "minimum": 0, "maximum": 100},
          "supporting_evidence": {"type": "array", "items": {"type": "string"}},
          "contradicting_evidence": {"type": "array", "items": {"type": "string"}},
          "falsification_conditions": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "discriminability": {
      "type": "object",
      "description": "Data Discriminability Assessment (v6.0 Step C)",
      "properties": {
        "matrix": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "pair": {"type": "array", "items": {"type": "string"}, "minItems": 2, "maxItems": 2},
              "classification": {"type": "string", "enum": ["INDISTINGUISHABLE", "PARTIALLY_DISCRIMINABLE", "DISCRIMINABLE", "ONE_SIDE_EXCLUDED"]},
              "discriminating_signal_needed": {"type": "string"}
            }
          }
        },
        "indistinguishable_sets": {"type": "array", "items": {"type": "array", "items": {"type": "string"}}}
      }
    },
    "conclusion": {
      "type": "object",
      "required": ["diagnosis_type", "primary_finding"],
      "properties": {
        "diagnosis_type": {"type": "string", "enum": ["DETERMINED", "COMPETING_SET", "NEEDS_DATA"]},
        "primary_finding": {"type": "string"},
        "surviving_hypotheses": {"type": "array", "items": {"type": "string"}},
        "eliminated_hypotheses": {"type": "array", "items": {"type": "string"}},
        "competing_sets": {"type": "array", "items": {"type": "object"}},
        "data_gaps": {"type": "array", "items": {"type": "string"}}
      }
    },
    "recommendations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["action", "priority", "rationale"],
        "properties": {
          "action": {"type": "string"},
          "priority": {"type": "string", "enum": ["P0", "P1", "P2", "P3"]},
          "rationale": {"type": "string"},
          "evidence_ref": {"type": "string"}
        }
      }
    },
    "uncertainties": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["description", "type", "impact"],
        "properties": {
          "description": {"type": "string"},
          "type": {"type": "string", "enum": ["aleatory", "epistemic", "model"]},
          "impact": {"type": "string", "enum": ["high", "medium", "low"]},
          "affected_hypotheses": {"type": "array", "items": {"type": "string"}},
          "resolution": {"type": "string"}
        }
      }
    }
  }
}
