{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Analysis Schema",
  "description": "Schema for diagnostic analysis results",
  "type": "object",
  "required": ["abnormal_intervals", "correlations", "root_causes", "confidence", "uncertainties"],
  "properties": {
    "abnormal_intervals": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "start", "end", "severity", "observations"],
        "properties": {
          "id": {"type": "string"},
          "start": {"type": "string", "format": "date-time"},
          "end": {"type": "string", "format": "date-time"},
          "severity": {"type": "string", "enum": ["low", "medium", "high", "critical"]},
          "observations": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["signal", "description", "evidence", "confidence"],
              "properties": {
                "signal": {"type": "string"},
                "description": {"type": "string"},
                "evidence": {
                  "type": "object",
                  "required": ["type"],
                  "properties": {
                    "type": {"type": "string", "enum": ["data", "stats", "visual", "reference", "web"]},
                    "details": {"type": "string"},
                    "source": {"type": "string"}
                  }
                },
                "confidence": {"type": "string", "enum": ["high", "medium", "low"]}
              }
            }
          },
          "correlations": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "signals": {"type": "array", "items": {"type": "string"}, "minItems": 2, "maxItems": 2},
                "correlation_type": {"type": "string", "enum": ["simultaneous", "leading", "lagging"]},
                "strength": {"type": "string", "enum": ["strong", "moderate", "weak"]},
                "lag_seconds": {"type": "number"},
                "correlation_value": {"type": "number", "minimum": -1, "maximum": 1}
              }
            }
          },
          "hypotheses": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["description", "mechanism", "confidence", "confidence_score"],
              "properties": {
                "description": {"type": "string"},
                "mechanism": {"type": "string"},
                "supporting_evidence": {"type": "array", "items": {"type": "string"}},
                "contradicting_evidence": {"type": "array", "items": {"type": "string"}},
                "confidence": {"type": "string", "enum": ["high", "medium", "low"]},
                "confidence_score": {"type": "number", "minimum": 0, "maximum": 100},
                "validation_needed": {"type": "array", "items": {"type": "string"}}
              }
            }
          },
          "primary_hypothesis": {"type": "string"},
          "root_cause_probability": {"type": "number", "minimum": 0, "maximum": 1}
        }
      }
    },
    "correlations": {
      "type": "object",
      "properties": {
        "pearson": {"type": "object", "additionalProperties": {"additionalProperties": {"type": "number"}, "type": "object"}},
        "lagged": {"type": "object", "additionalProperties": {}}
      }
    },
    "root_causes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["description", "evidence_refs", "confidence"],
        "properties": {
          "description": {"type": "string"},
          "evidence_refs": {"type": "array", "items": {"type": "string"}},
          "confidence": {"type": "string", "enum": ["high", "medium", "low"]},
          "confidence_score": {"type": "number"},
          "mechanism": {"type": "string"},
          "validation_steps": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "recommendations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["action", "priority", "rationale"],
        "properties": {
          "action": {"type": "string"},
          "priority": {"type": "string", "enum": ["high", "medium", "low"]},
          "rationale": {"type": "string"},
          "evidence_ref": {"type": "string"}
        }
      }
    },
    "confidence": {
      "type": "object",
      "required": ["overall", "primary_diagnosis"],
      "properties": {
        "overall": {"type": "string", "enum": ["high", "medium", "low"]},
        "overall_score": {"type": "number", "minimum": 0, "maximum": 100},
        "primary_diagnosis": {"type": "string"},
        "per_conclusion": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "conclusion": {"type": "string"},
              "confidence": {"type": "string"},
              "confidence_score": {"type": "number"},
              "evidence_rank": {"type": "integer", "minimum": 1, "maximum": 7}
            }
          }
        }
      }
    },
    "uncertainties": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["description", "impact"],
        "properties": {
          "description": {"type": "string"},
          "impact": {"type": "string", "enum": ["high", "medium", "low"]},
          "affected_conclusions": {"type": "array", "items": {"type": "string"}},
          "recommended_validation": {"type": "string"}
        }
      }
    }
  }
}
