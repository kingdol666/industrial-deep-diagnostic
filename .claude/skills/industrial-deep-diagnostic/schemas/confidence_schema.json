{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Confidence Schema v6.0",
  "description": "Schema for diagnostic confidence assessment (5-factor breakdown with adjustment log)",
  "type": "object",
  "required": ["run_id", "diagnosis_time", "confidence_breakdown", "overall_confidence", "adjustment_log"],
  "properties": {
    "run_id": {"type": "string"},
    "diagnosis_time": {"type": "string", "format": "date-time"},
    "confidence_breakdown": {
      "type": "object",
      "description": "Per-hypothesis 5-factor confidence scoring",
      "additionalProperties": {
        "type": "object",
        "required": ["hypothesis_id", "confidence_score", "level", "five_factor_breakdown"],
        "properties": {
          "hypothesis_id": {"type": "string", "pattern": "^H[0-9]+$"},
          "confidence_score": {"type": "integer", "minimum": 0, "maximum": 100},
          "level": {"type": "string", "enum": ["HIGH", "MEDIUM", "LOW", "VERY_LOW", "EXCLUDED"]},
          "five_factor_breakdown": {
            "type": "object",
            "required": ["statistical_strength", "physical_plausibility", "temporal_evidence", "absence_of_confounds", "symptom_completeness"],
            "properties": {
              "statistical_strength": {
                "type": "object",
                "description": "Correlation magnitude, consistency across products, validation checks passed (0-25)",
                "properties": {
                  "score": {"type": "integer", "minimum": 0, "maximum": 25},
                  "max": {"type": "integer", "const": 25},
                  "note": {"type": "string"}
                }
              },
              "physical_plausibility": {
                "type": "object",
                "description": "Quantitative mechanism check — Arrhenius, residence-time, energy-balance feasibility (0-25)",
                "properties": {
                  "score": {"type": "integer", "minimum": 0, "maximum": 25},
                  "max": {"type": "integer", "const": 25},
                  "note": {"type": "string"}
                }
              },
              "temporal_evidence": {
                "type": "object",
                "description": "Temporal precedence, CCF lag window, Granger causality (0-20)",
                "properties": {
                  "score": {"type": "integer", "minimum": 0, "maximum": 20},
                  "max": {"type": "integer", "const": 20},
                  "note": {"type": "string"}
                }
              },
              "absence_of_confounds": {
                "type": "object",
                "description": "No Simpson's Paradox, no trend confounding, not outlier-driven (0-20)",
                "properties": {
                  "score": {"type": "integer", "minimum": 0, "maximum": 20},
                  "max": {"type": "integer", "const": 20},
                  "note": {"type": "string"}
                }
              },
              "symptom_completeness": {
                "type": "object",
                "description": "All predicted observables match data, no unexplained contradictions (0-10)",
                "properties": {
                  "score": {"type": "integer", "minimum": 0, "maximum": 10},
                  "max": {"type": "integer", "const": 10},
                  "note": {"type": "string"}
                }
              }
            }
          },
          "evidence_gaps": {
            "type": "array",
            "items": {"type": "string"}
          },
          "assumptions": {
            "type": "array",
            "items": {"type": "string"}
          },
          "uncertainty_decomposition": {
            "type": "object",
            "properties": {
              "aleatory": {"type": "string", "description": "Irreducible — process noise, measurement error"},
              "epistemic": {"type": "string", "description": "Reducible — missing data, unmeasured parameter"},
              "model": {"type": "string", "description": "Methods limitation — linear vs nonlinear"}
            }
          }
        }
      }
    },
    "overall_confidence": {
      "type": "object",
      "required": ["score", "level", "summary"],
      "properties": {
        "score": {"type": "integer", "minimum": 0, "maximum": 100},
        "level": {"type": "string", "enum": ["HIGH", "MEDIUM", "LOW", "VERY_LOW"]},
        "summary": {"type": "string"}
      }
    },
    "adjustment_log": {
      "type": "array",
      "description": "Every confidence adjustment applied, in order",
      "items": {
        "type": "object",
        "required": ["hypothesis_id", "adjustment", "reason", "source"],
        "properties": {
          "hypothesis_id": {"type": "string", "pattern": "^H[0-9]+$"},
          "adjustment": {"type": "integer"},
          "reason": {"type": "string"},
          "source": {"type": "string", "description": "Which analysis triggered this adjustment (e.g., validate_report.json, discriminability matrix)"}
        }
      }
    },
    "confidence_ceilings_applied": {
      "type": "array",
      "description": "Any confidence ceilings in effect and why",
      "items": {
        "type": "object",
        "properties": {
          "hypothesis_id": {"type": "string"},
          "ceiling": {"type": "integer"},
          "reason": {"type": "string", "enum": ["INDISTINGUISHABLE_COMPETING_SET", "UNSORTED_DATA_LAG_CLAIMS", "PRODUCT_SPECIFIC_ONLY", "ALL_CRITERIA_VERIFIED", "DIRECT_MEASUREMENT"]}
        }
      }
    }
  }
}
