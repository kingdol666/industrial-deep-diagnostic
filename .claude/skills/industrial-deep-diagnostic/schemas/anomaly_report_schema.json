{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "Anomaly Report Schema v6.3",
  "description": "Schema for anomaly detection output from Data Processor Step 4.3. Contains anomaly intervals, threshold analysis, transition events, and pre-computed quality reset analysis consumed by the Diagnostician.",
  "type": "object",
  "required": ["targets", "transition_events"],
  "properties": {
    "targets": {
      "type": "object",
      "description": "Per-quality-target anomaly analysis",
      "additionalProperties": {
        "type": "object",
        "required": ["anomaly_intervals", "threshold_analysis"],
        "properties": {
          "anomaly_intervals": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["start_index", "end_index", "severity"],
              "properties": {
                "start_index": {"type": "integer", "minimum": 0},
                "end_index": {"type": "integer", "minimum": 0},
                "severity": {"type": "string", "enum": ["low", "medium", "high", "critical"]},
                "max_deviation_sigma": {"type": "number"},
                "concurrent_params": {
                  "type": "object",
                  "additionalProperties": {"type": "string"}
                }
              }
            }
          },
          "threshold_analysis": {
            "type": "object",
            "properties": {
              "critical_threshold": {"type": "number"},
              "threshold_crossing_index": {"type": "integer"},
              "percent_above_threshold": {"type": "number", "minimum": 0, "maximum": 100}
            }
          }
        }
      }
    },
    "transition_events": {
      "type": "array",
      "description": "Detected categorical column change events",
      "items": {
        "type": "object",
        "required": ["index", "type", "column"],
        "properties": {
          "index": {"type": "integer", "minimum": 0},
          "type": {"type": "string", "description": "e.g., tool_change, material_switch, shift_change, grade_change"},
          "column": {"type": "string"},
          "from": {"type": "string"},
          "to": {"type": "string"},
          "quality_before": {"type": "object", "additionalProperties": {"type": "number"}},
          "quality_after": {"type": "object", "additionalProperties": {"type": "number"}},
          "quality_jump_sigma": {"type": "number"}
        }
      }
    },
    "quality_reset_analysis": {
      "type": "object",
      "description": "PRE-COMPUTED quality reset analysis. For each transition event, analyzes whether quality resets (improves) after component replacement — the single most powerful test for distinguishing component-level vs system-level root causes. Generated by physics_check.py.",
      "required": ["reset_found", "details", "summary"],
      "properties": {
        "reset_found": {
          "type": "boolean",
          "description": "True if ANY transition shows quality reset (component replacement was effective)"
        },
        "total_transitions_analyzed": {
          "type": "integer",
          "description": "Number of transition events analyzed"
        },
        "details": {
          "type": "array",
          "description": "Per-transition-per-quality-metric analysis",
          "items": {
            "type": "object",
            "required": ["transition_index", "quality_metric", "reset_detected", "reset_classification"],
            "properties": {
              "transition_index": {"type": "integer", "description": "Row index of the transition event"},
              "transition_type": {"type": "string", "description": "e.g., tool_change, material_switch"},
              "from": {"type": "string", "description": "Previous categorical value"},
              "to": {"type": "string", "description": "New categorical value"},
              "quality_metric": {"type": "string", "description": "Which quality metric was analyzed"},
              "mean_before": {"type": "number", "description": "Mean quality value BEFORE transition (context window of ~20 points)"},
              "mean_after": {"type": "number", "description": "Mean quality value AFTER transition (context window of ~20 points)"},
              "effect_size_cohens_d": {"type": "number", "description": "Cohen's d effect size for before/after difference"},
              "reset_detected": {"type": "boolean", "description": "True if quality significantly improved after component replacement"},
              "reset_classification": {"type": "string", "enum": ["RESET", "NO_RESET", "WORSENED", "INCONCLUSIVE"]},
              "interpretation": {"type": "string", "description": "Natural language interpretation of the reset analysis"},
              "n_before": {"type": "integer", "description": "Number of data points in the 'before' window"},
              "n_after": {"type": "integer", "description": "Number of data points in the 'after' window"}
            }
          }
        },
        "summary": {
          "type": "string",
          "description": "One-sentence summary of overall reset analysis (e.g., 'Tool change shows NO quality reset — degradation is system-level')"
        }
      }
    }
  }
}
