{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "Run Summary Schema v6.0",
  "description": "Schema for run_summary.json generated by the Reporter. Provides metadata summary for downstream consumers.",
  "type": "object",
  "required": ["run_id", "scene_name", "timestamp", "pipeline_steps_completed", "diagnosis_type", "judge_verdict"],
  "properties": {
    "run_id": {"type": "string", "description": "Unique run identifier from directory name"},
    "scene_name": {"type": "string"},
    "timestamp": {"type": "string", "format": "date-time"},
    "pipeline_steps_completed": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["setup", "inspect", "context_builder", "clarification_gate", "data_processor", "diagnostician", "judge", "reporter", "audit"]
      }
    },
    "diagnosis_type": {
      "type": "string",
      "enum": ["DETERMINED", "COMPETING_SET", "NEEDS_DATA"]
    },
    "primary_finding": {"type": "string"},
    "judge_verdict": {
      "type": "object",
      "properties": {
        "score": {"type": "integer", "minimum": 0, "maximum": 100},
        "verdict": {"type": "string", "enum": ["pass", "needs_repair", "major_issues", "fail"]}
      }
    },
    "audit_verdict": {
      "type": "object",
      "properties": {
        "verdict": {"type": "string", "enum": ["ENDORSED", "CONDITIONAL", "REJECTED"]},
        "physical_match_rating": {"type": "integer", "minimum": 0, "maximum": 10}
      }
    },
    "report_stats": {
      "type": "object",
      "properties": {
        "total_lines": {"type": "integer"},
        "sections_count": {"type": "integer"},
        "figures_referenced": {"type": "integer"},
        "file_size_bytes": {"type": "integer"}
      }
    },
    "figure_count": {"type": "integer"},
    "data_sources": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "source": {"type": "string"},
          "rows": {"type": "integer"},
          "columns": {"type": "integer"}
        }
      }
    },
    "diagnostic_iterations": {"type": "integer", "minimum": 1}
  }
}