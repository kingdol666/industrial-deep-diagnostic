{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "Causal Evidence Map Schema v6.0",
  "description": "Schema for the causal evidence map generated by Data Processor. A validated directed graph showing statistically supported causal relationships with physical annotations.",
  "type": "object",
  "required": ["edges", "colinear_groups", "root_cause_candidates"],
  "properties": {
    "edges": {
      "type": "array",
      "description": "Validated causal edges between parameters. Each edge represents a correlation that survives statistical validation checks.",
      "items": {
        "type": "object",
        "required": ["from", "to", "r", "p_value", "method"],
        "properties": {
          "from": {"type": "string", "description": "Source parameter name"},
          "to": {"type": "string", "description": "Target parameter name (effect)"},
          "r": {"type": "number", "description": "Correlation coefficient"},
          "p_value": {"type": "number", "minimum": 0, "maximum": 1},
          "method": {"type": "string", "enum": ["pearson", "spearman", "mutual_information", "maximal_information_coefficient", "granger_causality"]},
          "detrended_r": {"type": "number", "description": "Correlation after linear detrending"},
          "attenuation_pct": {"type": "number", "description": "Percent attenuation after detrending"},
          "simpson_checked": {"type": "boolean", "default": false},
          "simpson_reversal": {"type": "boolean", "default": false},
          "outlier_sensitive": {"type": "boolean", "default": false},
          "lag": {"type": "integer", "description": "Optimal lag (for CCF analysis). Positive = from leads to."},
          "direction_consistency": {
            "type": "string",
            "enum": ["UNIVERSAL", "CONSISTENT_SIGN", "BETWEEN_PRODUCT_ONLY", "SIMPSON_REVERSAL", "INSUFFICIENT_DATA"]
          },
          "physical_interpretation": {"type": "string", "description": "What physical mechanism this edge represents"},
          "strength": {"type": "string", "enum": ["strong", "moderate", "weak"]},
          "evidence_rank": {"type": "integer", "minimum": 1, "maximum": 7}
        }
      }
    },
    "colinear_groups": {
      "type": "array",
      "description": "Groups of parameters that are highly colinear with each other.",
      "items": {
        "type": "object",
        "required": ["group_id", "members", "mean_intra_r"],
        "properties": {
          "group_id": {"type": "string", "pattern": "^CG[0-9]+$"},
          "members": {
            "type": "array",
            "items": {"type": "string"},
            "minItems": 2
          },
          "mean_intra_r": {"type": "number", "description": "Mean correlation among members"},
          "physical_interpretation": {"type": "string", "description": "What physical quantity these parameters collectively represent"},
          "break_down_condition": {"type": "string", "description": "Under what conditions the colinearity breaks (e.g., 'within product group')"}
        }
      }
    },
    "root_cause_candidates": {
      "type": "array",
      "description": "Parameters identified as potential root causes through causal graph analysis.",
      "items": {
        "type": "object",
        "required": ["parameter", "score", "reason"],
        "properties": {
          "parameter": {"type": "string"},
          "score": {"type": "number", "minimum": 0, "maximum": 1, "description": "Causal importance score combining degree centrality + cross-validation survival"},
          "reason": {"type": "string"},
          "edges_influenced": {
            "type": "array",
            "items": {"type": "string"},
            "description": "Edges originating from this parameter"
          }
        }
      }
    },
    "scenario": {
      "type": "string",
      "description": "The scenario classification used for this analysis (e.g., 'ball_mill_grinding')"
    },
    "generation_time": {"type": "string", "format": "date-time"},
    "data_points_used": {"type": "integer", "description": "Number of data points in the analysis"}
  }
}