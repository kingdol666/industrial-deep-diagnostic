{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Industrial Ontology Schema v6.0",
  "description": "Schema for industrial process ontology used in v6.0 deep diagnostic (Competing Hypotheses Protocol). Includes product grades, confounders, parameter groups, and physical meaning confidence.",
  "type": "object",
  "required": ["scene", "signals", "relationships", "metadata"],
  "properties": {
    "scene": {
      "type": "object",
      "required": ["name", "process_type"],
      "properties": {
        "name": {"type": "string", "description": "Scene identifier name"},
        "process_type": {"type": "string", "description": "Type of industrial process"},
        "production_goal": {"type": "string"},
        "equipment": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "name", "type"],
            "properties": {
              "id": {"type": "string"},
              "name": {"type": "string"},
              "type": {"type": "string"},
              "function": {"type": "string"},
              "location": {"type": "string"},
              "manufacturer": {"type": "string"},
              "model": {"type": "string"}
            }
          }
        },
        "stages": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "name", "sequence"],
            "properties": {
              "id": {"type": "string"},
              "name": {"type": "string"},
              "sequence": {"type": "integer", "minimum": 0},
              "typical_duration": {"type": "string"},
              "key_physics": {"type": "string"},
              "key_parameters": {"type": "array", "items": {"type": "string"}}
            }
          }
        },
        "objectives": {"type": "array", "items": {"type": "string"}}
      }
    },
    "signals": {
      "type": "object",
      "required": ["inspection_signals", "process_parameters", "control_variables", "events", "metadata_columns"],
      "properties": {
        "inspection_signals": {
          "type": "array",
          "items": {"$ref": "#/definitions/signal_v6"}
        },
        "process_parameters": {
          "type": "array",
          "items": {"$ref": "#/definitions/signal_v6"}
        },
        "control_variables": {
          "type": "array",
          "items": {"$ref": "#/definitions/control_signal_v6"}
        },
        "events": {
          "type": "array",
          "items": {"$ref": "#/definitions/event_v6"}
        },
        "metadata_columns": {
          "type": "array",
          "items": {"$ref": "#/definitions/metadata_v6"}
        }
      }
    },
    "parameter_groups": {
      "type": "object",
      "description": "v6.0: Parameters grouped by physical function for the Diagnostician's confounder analysis",
      "additionalProperties": {
        "type": "array",
        "items": {"type": "string"}
      }
    },
    "relationships": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["from", "to", "type"],
        "properties": {
          "from": {"type": "string"},
          "to": {"type": "string"},
          "type": {"type": "string", "enum": ["causal", "correlative", "control", "physical"]},
          "strength": {"type": "string", "enum": ["strong", "moderate", "weak"]},
          "mechanism": {"type": "string"},
          "time_lag": {"type": "string"},
          "inferred": {"type": "boolean", "default": false}
        }
      }
    },
    "confounders": {
      "type": "array",
      "description": "v6.0: Known confounders that could affect both predictors and targets",
      "items": {
        "type": "object",
        "properties": {
          "variable": {"type": "string"},
          "why": {"type": "string"},
          "controlled": {"type": "boolean"}
        }
      }
    },
    "metadata": {
      "type": "object",
      "properties": {
        "units": {"type": "object", "additionalProperties": {"type": "string"}},
        "sampling_rate": {"type": ["string", "number", "null"]},
        "batch_id": {"type": ["string", "null"]},
        "timezone": {"type": ["string", "null"]},
        "start_time": {"type": ["string", "null"], "format": "date-time"},
        "end_time": {"type": ["string", "null"], "format": "date-time"},
        "product_grades": {
          "type": "array",
          "description": "v6.0: Product grades/models for stratified analysis",
          "items": {
            "type": "object",
            "properties": {
              "name": {"type": "string"},
              "key_parameter_differences": {"type": "object"}
            }
          }
        }
      }
    }
  },
  "definitions": {
    "signal_v6": {
      "type": "object",
      "required": ["name", "column", "role"],
      "properties": {
        "name": {"type": "string"},
        "column": {"type": "string"},
        "unit": {"type": "string"},
        "role": {
          "type": "string",
          "enum": ["target", "predictor", "confounder", "control", "metadata"],
          "description": "v6.0: Analytical role classification"
        },
        "physical_meaning": {"type": "string", "description": "v6.0: What this parameter physically represents"},
        "physical_meaning_confidence": {
          "type": "string",
          "enum": ["KNOWN", "INFERRED", "UNKNOWN"],
          "description": "v6.0: Certainty of physical meaning determination"
        },
        "control_type": {
          "type": "string",
          "enum": ["setpoint", "measurement", "output"],
          "description": "v6.0: Whether this is a setpoint, measured value, or control output"
        },
        "target": {"type": ["number", "null"]},
        "tolerance": {"type": ["number", "null"]},
        "normal_range": {
          "type": "array",
          "items": {"type": ["number", "null"]},
          "minItems": 2,
          "maxItems": 2
        },
        "setpoint": {"type": ["number", "null"]},
        "controlled_by": {"type": "string"},
        "equipment_ref": {"type": "string"},
        "stage_ref": {"type": "string"}
      }
    },
    "control_signal_v6": {
      "type": "object",
      "required": ["name", "column", "role"],
      "properties": {
        "name": {"type": "string"},
        "column": {"type": "string"},
        "unit": {"type": "string"},
        "role": {"type": "string", "const": "control"},
        "physical_meaning": {"type": "string"},
        "control_type": {"type": "string", "enum": ["setpoint", "measurement", "output"]},
        "setpoint": {"type": ["number", "null"]},
        "controlled_by": {"type": "string"},
        "equipment_ref": {"type": "string"},
        "stage_ref": {"type": "string"}
      }
    },
    "event_v6": {
      "type": "object",
      "required": ["name", "column"],
      "properties": {
        "name": {"type": "string"},
        "column": {"type": "string"},
        "description": {"type": "string"},
        "event_values": {"type": "array", "items": {}},
        "event_meanings": {"type": "object", "additionalProperties": {"type": "string"}}
      }
    },
    "metadata_v6": {
      "type": "object",
      "required": ["name", "column", "role"],
      "properties": {
        "name": {"type": "string"},
        "column": {"type": "string"},
        "role": {
          "type": "string",
          "enum": ["batch_id", "product_code", "timestamp", "operator"],
          "description": "v6.0: Specific metadata role"
        },
        "description": {"type": "string"}
      }
    }
  }
}
