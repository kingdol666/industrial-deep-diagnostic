{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Run Configuration Schema",
  "description": "Schema for configuring a diagnostic run",
  "type": "object",
  "required": ["data_path"],
  "properties": {
    "data_path": {
      "type": "string",
      "description": "Path to time-series data file"
    },
    "ontology_path": {
      "type": "string",
      "description": "Path to pre-defined ontology JSON"
    },
    "reference_dir": {
      "type": "string",
      "description": "Directory with reference documents"
    },
    "process_description": {
      "type": "string",
      "description": "Free-text description of the industrial process"
    },
    "scene_name": {
      "type": "string",
      "description": "Name for this diagnostic scene"
    },
    "batch_id": {
      "type": "string",
      "description": "Production batch identifier"
    },
    "output_dir": {
      "type": "string",
      "description": "Override default output directory"
    },
    "user_objective": {
      "type": "string",
      "description": "Specific analysis objective"
    },
    "known_faults": {
      "type": "array",
      "items": {"type": "string"},
      "description": "Known fault patterns"
    },
    "analysis_constraints": {
      "type": "object",
      "properties": {
        "time_range": {
          "type": "object",
          "properties": {
            "start": {"type": "string", "format": "date-time"},
            "end": {"type": "string", "format": "date-time"}
          }
        },
        "focus_signals": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Signals to prioritize in analysis"
        },
        "exclude_signals": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Signals to exclude from analysis"
        },
        "max_web_research_queries": {
          "type": "integer",
          "default": 5,
          "minimum": 0,
          "maximum": 10
        },
        "judge_score_threshold": {
          "type": "integer",
          "default": 90,
          "minimum": 50,
          "maximum": 100
        },
        "max_iterations": {
          "type": "integer",
          "default": 3,
          "minimum": 1,
          "maximum": 5
        }
      }
    }
  }
}
